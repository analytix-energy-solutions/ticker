# Ignore everything by default
*

# Allow repo root files
!.gitignore
!hacs.json
!LICENSE
!README.md

# Allow GitHub config
!.github/
!.github/**

# Allow integration source
!custom_components/
!custom_components/ticker/
!custom_components/ticker/**

# Allow tests
!tests/
!tests/**

# Python artifacts (within allowed paths)
__pycache__/
*.py[cod]
